# --- Recommended if you do NOT have OpenAI / foreign payment ---

# Google Gemini (free tier on Google AI Studio, no OpenAI account needed)
LLM_PROVIDER=google
GOOGLE_GENERATIVE_AI_API_KEY=
GOOGLE_CHAT_MODEL=gemini-2.0-flash

# --- Alternative: Chinese-friendly OpenAI-compatible APIs ---

# DeepSeek example:
# LLM_PROVIDER=openai-compatible
# OPENAI_API_KEY=your-deepseek-key
# OPENAI_COMPAT_BASE_URL=https://api.deepseek.com/v1
# OPENAI_CHAT_MODEL=deepseek-chat

# Moonshot (Kimi) example:
# OPENAI_COMPAT_BASE_URL=https://api.moonshot.cn/v1
# OPENAI_CHAT_MODEL=moonshot-v1-8k

# --- OpenAI official (optional) ---

# LLM_PROVIDER=openai-compatible
# OPENAI_API_KEY=
# OPENAI_CHAT_MODEL=gpt-4o-mini

# Railway compile worker (Phase 2) — when set, /api/generate returns .mobi
COMPILE_WORKER_URL=
COMPILE_WORKER_SECRET=
