# Vercel production (alalei719s-projects/kindledict) — configured keys:
#   KINDLE_DICT_BYOK_REQUIRED=false
#   GOOGLE_GENERATIVE_AI_API_KEY=<secret on Vercel>
#   COMPILE_WORKER_URL=<secret on Vercel; Production + Preview>
#   COMPILE_WORKER_SECRET=<secret on Vercel; Production + Preview>
#   COMPILE_WORKER_FALLBACK_ZIP=<on Vercel; Production + Preview>
# Still optional on Vercel: NEXT_PUBLIC_KINDLE_DICT_PAYMENT_LINK_URL
# Sync locally: vercel env pull .env.local --environment=production --yes

# --- Hosted generation ---

# Set false when you want the normal user path to use your server-side AI key.
# Set true only for BYOK public demos where users must bring their own API key.
KINDLE_DICT_BYOK_REQUIRED=false

# --- Optional server-side AI (self-host / internal testing only) ---

# Google Gemini (free tier on Google AI Studio, no OpenAI account needed)
LLM_PROVIDER=google
GOOGLE_GENERATIVE_AI_API_KEY=
GOOGLE_CHAT_MODEL=gemini-2.5-flash

# --- Alternative: Chinese-friendly OpenAI-compatible APIs ---

# DeepSeek example:
# LLM_PROVIDER=openai-compatible
# OPENAI_API_KEY=your-deepseek-key
# OPENAI_COMPAT_BASE_URL=https://api.deepseek.com/v1
# OPENAI_CHAT_MODEL=deepseek-chat

# Moonshot (Kimi) example:
# OPENAI_COMPAT_BASE_URL=https://api.moonshot.cn/v1
# OPENAI_CHAT_MODEL=moonshot-v1-8k

# --- OpenAI official (optional) ---

# LLM_PROVIDER=openai-compatible
# OPENAI_API_KEY=
# OPENAI_CHAT_MODEL=gpt-4o-mini

# Compile worker — when set, /api/build and /api/generate return .mobi first.
COMPILE_WORKER_URL=
COMPILE_WORKER_SECRET=

# Optional: if the compile worker fails, keep ZIP fallback enabled by default.
# Set to false if you prefer hard failures instead of ZIP downloads.
COMPILE_WORKER_FALLBACK_ZIP=true

# Launch access & account sync
KINDLE_DICT_TRIAL_SECRET=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Creem checkout + webhook
CREEM_API_KEY=
CREEM_PRODUCT_ID=
CREEM_WEBHOOK_SECRET=
# Optional: set to https://test-api.creem.io when using Creem test mode
CREEM_API_BASE_URL=
# Optional: stored on customer_access.plan_slug
CREEM_PLAN_SLUG=reader-access

# Optional fallback external checkout link shown only when the internal Creem
# checkout flow is not configured.
NEXT_PUBLIC_KINDLE_DICT_PAYMENT_LINK_URL=
