# OpenAI or compatible gateway — required for AI extraction
OPENAI_API_KEY=

# Optional: use a non-OpenAI gateway that speaks the OpenAI API
# Examples: DeepSeek, Together, OpenRouter, Azure OpenAI (with compatible path)
OPENAI_COMPAT_BASE_URL=
# OPENAI_COMPAT_API_KEY=   # optional override; otherwise OPENAI_API_KEY is used

# Model id understood by your provider (default: gpt-4o-mini)
OPENAI_CHAT_MODEL=gpt-4o-mini

# Railway compile worker (Phase 2) — when set, /api/generate returns .mobi
COMPILE_WORKER_URL=
COMPILE_WORKER_SECRET=
